Bootstrap: docker
From: ubuntu:24.04

%files
    skills/wss-profiler/SKILL.md  /skills/wss-profiler/SKILL.md
    wss_profiler.h                /skills/wss-profiler/wss_profiler.h
    wss_profiler.h                /usr/local/include/wss_profiler.h

%environment
    export DEBIAN_FRONTEND=noninteractive

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update && apt-get install -y \
        gcc g++ gfortran make \
        openmpi-bin libopenmpi-dev \
        libpapi-dev papi-tools \
        linux-tools-generic linux-tools-common \
        curl git strace procps \
    && PERF_BIN=$(find /usr/lib/linux-tools-* -name perf -type f | head -1) \
    && ln -sf "$PERF_BIN" /usr/local/bin/perf \
    && rm -rf /var/lib/apt/lists/*

    # Claude Code — install and force HOME=/root so all config lands in /root
    HOME=/root curl -fsSL https://claude.ai/install.sh | bash

    # Symlink claude into a system path so it works regardless of $HOME at runtime
    ln -sf /root/.local/bin/claude /usr/local/bin/claude

    # Write our config after the installer, using absolute paths.
    mkdir -p /root/.claude/commands

    # API key helper — reads ANTHROPIC_API_KEY from the environment at runtime
    printf '{\n  "apiKeyHelper": "echo $ANTHROPIC_API_KEY"\n}\n' \
        > /root/.claude/settings.json

    # Bake in the wss-profiler slash command
    cp /skills/wss-profiler/SKILL.md /root/.claude/commands/wss-profiler.md

%runscript
    # Singularity maps the real user's $HOME, not /root, so copy baked-in
    # Claude config to the user's home on first run.
    mkdir -p "$HOME/.claude/commands"

    cp /root/.claude/settings.json "$HOME/.claude/settings.json"

    cp /root/.claude/commands/wss-profiler.md \
       "$HOME/.claude/commands/wss-profiler.md"

    if [ -f /skills/my-code/SKILL.md ]; then
        cp /skills/my-code/SKILL.md "$HOME/.claude/commands/my-code.md"
    fi

    exec "$@"

%labels
    Maintainer wddawson
    Description WSS profiler + Claude Code for HPC MPI/OpenMP codes
