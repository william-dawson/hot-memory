Bootstrap: docker
From: ubuntu:24.04

%files
    skills/wss-profiler/SKILL.md      /skills/wss-profiler/SKILL.md
    wss_profiler/wss_profiler.h       /skills/wss-profiler/wss_profiler.h
    wss_profiler/wss_profiler.h       /usr/local/include/wss_profiler.h
    wss_profiler/wss_profiler_f.c     /usr/local/include/wss_profiler_f.c
    wss_profiler/wss_profiler_mod.f90 /usr/local/include/wss_profiler_mod.f90

%environment
    export DEBIAN_FRONTEND=noninteractive
    export CLAUDE_CODE_USE_BEDROCK=1
    export AWS_REGION="us-east-1"
    export OPENAI_BASE_URL="https://bedrock-mantle.us-east-1.api.aws/v1"
    export HOME=/tmp/claude-home
    export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
    export OMPI_ALLOW_RUN_AS_ROOT=1
    export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
    export OMPI_MCA_rmaps_base_oversubscribe=1

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update && apt-get install -y \
        gcc g++ gfortran make \
        openmpi-bin libopenmpi-dev \
        libpapi-dev papi-tools \
        linux-tools-generic linux-tools-common \
        curl git strace procps time \
    && PERF_BIN=$(find /usr/lib/linux-tools-* -name perf -type f | head -1) \
    && ln -sf "$PERF_BIN" /usr/local/bin/perf \
    && rm -rf /var/lib/apt/lists/*

    # Node.js + Claude Code installed to a fixed system path
    curl -fsSL https://deb.nodesource.com/setup_lts.x | bash -
    apt-get install -y nodejs
    npm install -g @anthropic-ai/claude-code
    rm -rf /var/lib/apt/lists/*

    # Pre-compile the WSS profiler library (C wrapper + Fortran module)
    # so users just link with -lwss_profiler -lpapi, no source copying needed.
    cd /usr/local/include
    mpicc -DPROFILE_WSS -c wss_profiler_f.c -o wss_profiler_f.o
    mpif90 -c wss_profiler_mod.f90 -o wss_profiler_mod.o
    ar rcs /usr/local/lib/libwss_profiler.a wss_profiler_f.o wss_profiler_mod.o
    cp wss_profiler_mod.mod /usr/local/include/ 2>/dev/null || true
    rm -f wss_profiler_f.o wss_profiler_mod.o

    # Bake container setup into bash profile so it runs even when
    # Singularity falls back to sandbox extraction (which skips %runscript).
    cat >> /etc/bash.bashrc << 'BASHRC'

# ── hotmemory container setup ──
export HOME=/tmp/claude-home
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
export CLAUDE_CODE_USE_BEDROCK=1
export AWS_REGION="us-east-1"
export OPENAI_BASE_URL="https://bedrock-mantle.us-east-1.api.aws/v1"
export OMPI_ALLOW_RUN_AS_ROOT=1
export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1
export OMPI_MCA_rmaps_base_oversubscribe=1
export OMP_NUM_THREADS=1

mkdir -p "$HOME/.claude/commands"
cp /skills/wss-profiler/SKILL.md "$HOME/.claude/commands/wss-profiler.md" 2>/dev/null
if [ -f /skills/my-code/SKILL.md ]; then
    cp /skills/my-code/SKILL.md "$HOME/.claude/commands/my-code.md"
fi

# Generate environment info from live hardware probes.
NCPUS=$(grep -c processor /proc/cpuinfo 2>/dev/null || echo "unknown")
ARCH=$(uname -m 2>/dev/null || echo "unknown")
PERF_OK="no"
perf stat echo ok >/dev/null 2>&1 && PERF_OK="yes"
PAPI_FP=$(papi_avail 2>&1 | grep -cE 'PAPI_DP_OPS|PAPI_SP_OPS|PAPI_FP_OPS' || echo 0)
PAPI_MEM=$(papi_avail 2>&1 | grep -cE 'PAPI_LD_INS|PAPI_SR_INS' || echo 0)
PAPI_FP_STR=$( [ "$PAPI_FP" -gt 0 ] && echo "available" || echo "not available" )
PAPI_MEM_STR=$( [ "$PAPI_MEM" -gt 0 ] && echo "available" || echo "not available" )

# Write settings.json with systemPrompt so Claude reads environment
# info automatically on every interaction — no skill invocation needed.
cat > "$HOME/.claude/settings.json" << SETTINGS
{
  "systemPrompt": "You are inside a hot-memory profiling container. Architecture: $ARCH. CPUs available: $NCPUS. perf hardware counters: $PERF_OK. PAPI FP counters: $PAPI_FP_STR. PAPI load/store counters: $PAPI_MEM_STR. RULES: (1) Do not use OpenMP — build with it disabled, OMP_NUM_THREADS=1 is set. (2) This machine has $NCPUS CPUs. WARNING: nproc returns 1 inside this container because Singularity fakeroot restricts cgroup CPU visibility. This is a known bug. The actual CPU count is $NCPUS (detected from /proc/cpuinfo). Do NOT trust nproc — use $NCPUS for MPI -np. To verify, run: grep -c processor /proc/cpuinfo. (3) Use /wss-profiler for the profiling workflow. (4) Use /my-code for the target project."
}
SETTINGS
BASHRC

%runscript
    # Ensure the clean HOME exists with skills installed
    mkdir -p "$HOME/.claude/commands"

    cp /skills/wss-profiler/SKILL.md "$HOME/.claude/commands/wss-profiler.md"

    if [ -f /skills/my-code/SKILL.md ]; then
        cp /skills/my-code/SKILL.md "$HOME/.claude/commands/my-code.md"
    fi

    cd /workspace
    exec "$@"

%labels
    Maintainer wddawson
    Description WSS profiler + Claude Code for HPC MPI/OpenMP codes
